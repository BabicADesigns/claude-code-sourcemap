# Meta App Credentials (von developers.facebook.com)
META_ACCESS_TOKEN=your_long_lived_user_access_token_here
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Instagram Business Account ID
# (findbar über Facebook Page Settings → Instagram → "Instagram Account ID")
IG_USER_ID=your_instagram_business_account_id_here

# Meta Ad Account ID (für Marketing/Ads API)
# Format: act_XXXXXXXXXX — findbar im Meta Business Manager
META_AD_ACCOUNT_ID=act_your_ad_account_id_here
