# ── Site ──────────────────────────────────────────────────────────────────
# Used for metadataBase (OpenGraph/Twitter absolute URLs) and as the canonical
# origin in lib/env.ts's startup report. Falls back to the production URL
# below when unset, so this is optional for local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (Auth, Database, Storage) ──────────────────────────────────────
# Leave all three blank to run the app in prototype/mock-data mode — every
# data-layer read falls back to lib/data/*-mock.ts and every write returns a
# friendly "not connected yet" error instead of crashing. See
# docs/production-readiness.md "Environment Validation".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never exposed to the browser. Required for
# admin-only writes (anonymous itinerary logging in app/api/planner/route.ts).
# Without it the rest of Supabase (auth, user-scoped reads/writes) still works.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Planner (OpenAI) ──────────────────────────────────────────────────────
# Server-side only, used by app/api/planner/route.ts. Leave blank to fall back
# to the deterministic grounding-only itinerary generator (lib/ai/itinerary.ts).
OPENAI_API_KEY=

# ── Analytics (Plausible) ───────────────────────────────────────────────────
# Optional — leave blank to disable tracking entirely.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Email Delivery (Resend) ─────────────────────────────────────────────────
# Server-side only, used by lib/email/send.ts for "Email PDF" / "Resend" actions
# in My Trips. Leave both blank to disable email delivery — Download/Regenerate
# still work, and the UI surfaces a friendly "email isn't set up yet" message
# instead of failing. See docs/pdf-delivery-architecture.md.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
